---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kontakt – NextKI Agentur | Kostenlose Erstberatung"
  description="Kontaktieren Sie NextKI für eine kostenlose Erstberatung. Wir besprechen Ihre Herausforderungen und zeigen KI-Potenziale auf."
>
  <section class="page-header">
    <div class="container">
      <h1>Kontakt</h1>
      <p>Lassen Sie uns über Ihr Projekt sprechen.</p>
    </div>
  </section>

  <section class="container content">
    <div class="contact-info">
      <h2>So erreichen Sie uns</h2>
      <p>
        <strong>Telefon:</strong> <a href="tel:+4923069469960">+49 2306 9469960</a><br />
        <strong>E-Mail:</strong> <a href="mailto:christian@synoradzki.de">christian@synoradzki.de</a>
      </p>
      <p>
        <strong>Adresse:</strong><br />
        Christian Synoradzki<br />
        Kreisstr. 76<br />
        44532 Lünen
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 4rem 0 2rem;
    background: var(--color-bg-alt);
  }

  .page-header h1 {
    font-size: 2rem;
    color: var(--color-primary);
  }

  .page-header p {
    color: var(--color-text-light);
    margin-top: 0.75rem;
  }

  .content {
    padding: 3rem 0;
  }

  .contact-info h2 {
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }
</style>
