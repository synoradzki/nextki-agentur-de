---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kontakt – NextKI Agentur | Kostenlose Erstberatung"
  description="Kontaktieren Sie NextKI für eine kostenlose Erstberatung. Wir besprechen Ihre Herausforderungen und zeigen KI-Potenziale auf."
>
  <section class="page-header">
    <div class="container">
      <span class="badge">Kontakt</span>
      <h1>Kontakt</h1>
      <p>Lassen Sie uns über Ihr Projekt sprechen.</p>
    </div>
  </section>

  <section class="container content">
    <div class="contact-card card">
      <h2>So erreichen Sie uns</h2>
      <p>
        <strong>Telefon:</strong> <a href="tel:+4923069469960">+49 2306 9469960</a><br />
        <strong>E-Mail:</strong> <a href="mailto:christian@synoradzki.de">christian@synoradzki.de</a>
      </p>
      <p>
        <strong>Adresse:</strong><br />
        Christian Synoradzki<br />
        Kreisstr. 76<br />
        44532 Lünen
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-4xl) 0 var(--space-2xl);
  }

  .page-header h1 {
    font-size: var(--font-size-4xl);
    color: var(--color-text-heading);
    font-weight: 700;
    margin-top: var(--space-md);
  }

  .page-header p {
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
  }

  .content {
    padding: var(--space-2xl) 0 var(--space-4xl);
  }

  .contact-card {
    max-width: 500px;
  }

  .contact-card h2 {
    font-size: var(--font-size-2xl);
    color: var(--color-text-heading);
    margin-bottom: var(--space-lg);
    font-weight: 600;
  }

  .contact-card p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
    line-height: 1.8;
  }

  .contact-card strong {
    color: var(--color-text);
  }
</style>
