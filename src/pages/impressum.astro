<style>
  .page-header {
    padding: 4rem 0 2rem;
    background: var(--color-bg-alt);
  }

  .page-header h1 {
    font-size: 2rem;
    color: var(--color-primary);
  }

  .content {
    padding: 3rem 0;
    max-width: 700px;
  }

  .content h2 {
    font-size: 1.25rem;
    color: var(--color-primary);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .content h2:first-of-type {
