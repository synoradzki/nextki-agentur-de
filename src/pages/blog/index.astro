---
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = [
  {
    title: "Intelligente Automatisierung: Was sie ist und wie Unternehmen sie einsetzen",
    description: "Intelligente Automatisierung geht über klassische Regelwerke hinaus. Dieser Leitfaden erklärt den Unterschied, zeigt Praxisbeispiele und beschreibt die Einführung im Mittelstand.",
    url: "/blog/intelligente-automatisierung/",
    date: "13. März 2026",
    badge: "KI Automatisierung"
  }
];
---

<BaseLayout
  title="Blog – KI Wissen & Insights | NextKI Agentur"
  description="Aktuelle Artikel über KI-Strategien, Automatisierung und Implementierung. Praxiswissen für Unternehmen."
>
  <section class="page-header">
    <div class="container">
      <span class="badge">Blog</span>
      <h1>Blog</h1>
      <p>Praxiswissen rund um Künstliche Intelligenz für Unternehmen.</p>
    </div>
  </section>

  <section class="container content">
    <div class="article-list">
      {articles.map(article => (
        <a href={article.url} class="article-card card">
          <div class="article-card-meta">
            <span class="badge">{article.badge}</span>
            <span class="article-date">{article.date}</span>
          </div>
          <h2>{article.title}</h2>
          <p>{article.description}</p>
          <span class="read-more">Artikel lesen →</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-4xl) 0 var(--space-2xl);
  }

  .page-header h1 {
    font-size: var(--font-size-4xl);
    color: var(--color-text-heading);
    font-weight: 700;
    margin-top: var(--space-md);
  }

  .page-header p {
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
  }

  .content {
    padding: var(--space-2xl) 0 var(--space-4xl);
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    max-width: 800px;
  }

  .article-card {
    display: block;
    padding: var(--space-xl);
    text-decoration: none;
    transition: border-color var(--transition-fast);
  }

  .article-card:hover {
    border-color: var(--color-accent);
  }

  .article-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .article-date {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .article-card h2 {
    font-size: var(--font-size-xl);
    color: var(--color-text-heading);
    font-weight: 600;
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }

  .article-card p {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .read-more {
    color: var(--color-accent);
    font-size: var(--font-size-sm);
    font-weight: 500;
  }
</style>
