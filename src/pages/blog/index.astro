---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Blog – KI Wissen & Insights | NextKI Agentur"
  description="Aktuelle Artikel über KI-Strategien, Automatisierung und Implementierung. Praxiswissen für Unternehmen."
>
  <section class="page-header">
    <div class="container">
      <span class="badge">Blog</span>
      <h1>Blog</h1>
      <p>Praxiswissen rund um Künstliche Intelligenz für Unternehmen.</p>
    </div>
  </section>

  <section class="container content">
    <p class="empty-state">Beiträge folgen in Kürze.</p>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-4xl) 0 var(--space-2xl);
  }

  .page-header h1 {
    font-size: var(--font-size-4xl);
    color: var(--color-text-heading);
    font-weight: 700;
    margin-top: var(--space-md);
  }

  .page-header p {
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
  }

  .content {
    padding: var(--space-2xl) 0 var(--space-4xl);
  }

  .empty-state {
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
