---
const year = new Date().getFullYear();
// Loop-Zähler: wird vom SEO-Loop aktualisiert
// Format: L[Anzahl Loops]·[Datum letztes Update YYMMDD]
const loopCounter = "L4·260313";
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-logo"><strong>NextKI</strong> Agentur</a>
        <p>KI-Lösungen für Unternehmen, die vorankommen wollen.</p>
      </div>
      <div class="footer-nav">
        <div class="footer-col">
          <h4>Leistungen</h4>
          <a href="/leistungen/">Übersicht</a>
          <a href="/leistungen/ki-beratung/">KI Beratung</a>
          <a href="/leistungen/ki-automatisierung/">KI Automatisierung</a>
        </div>
        <div class="footer-col">
          <h4>Unternehmen</h4>
          <a href="/ueber-uns/">Über uns</a>
          <a href="/blog/">Blog</a>
          <a href="/kontakt/">Kontakt</a>
        </div>
        <div class="footer-col">
          <h4>Rechtliches</h4>
          <a href="/impressum/">Impressum</a>
          <a href="/datenschutz/">Datenschutz</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {year} NextKI Agentur</p>
      <span class="loop-id" title="Loop-Status">{loopCounter}</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-dark-border);
    padding: var(--space-3xl) 0 var(--space-xl);
    margin-top: var(--space-4xl);
    background: var(--color-dark-surface);
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--color-dark-border);
  }

  .footer-brand {
    max-width: 280px;
  }

  .footer-logo {
    color: var(--color-text-heading);
    font-size: var(--font-size-lg);
  }

  .footer-logo:hover {
    color: var(--color-text-heading);
  }

  .footer-logo strong {
    background: var(--color-accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-brand p {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    margin-top: var(--space-sm);
    line-height: 1.6;
  }

  .footer-nav {
    display: flex;
    gap: var(--space-3xl);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .footer-col h4 {
    color: var(--color-text-heading);
    font-size: var(--font-size-sm);
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  .footer-col a {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .footer-col a:hover {
    color: var(--color-accent);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-xl);
  }

  .footer-bottom p {
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
  }

  .loop-id {
    color: var(--color-text-muted);
    font-size: 10px;
    font-family: monospace;
    opacity: 0.5;
    user-select: none;
  }

  @media (max-width: 768px) {
    .footer-top {
      flex-direction: column;
      gap: var(--space-xl);
    }

    .footer-nav {
      gap: var(--space-xl);
      flex-wrap: wrap;
    }
  }
</style>
