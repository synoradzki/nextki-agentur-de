---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description, canonical, ogImage, noindex = false } = Astro.props;
const siteUrl = 'https://nextki-agentur.de';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <SEOHead
      title={title}
      description={description}
      canonical={canonicalUrl}
      ogImage={ogImage}
      noindex={noindex}
    />
    <style is:global>
      /* ========================================
         DESIGN SYSTEM – NextKI Agentur
         GESCHÜTZT: Nicht durch den SEO-Loop ändern!
         ======================================== */

      :root {
        /* Farben – Light Mode */
        --color-dark: #ffffff;
        --color-dark-card: #f8f9fa;
        --color-dark-border: #e2e8f0;
        --color-dark-surface: #f1f5f9;

        --color-accent: #009ADE;
        --color-accent-light: #0080c0;
        --color-accent-glow: rgba(0, 154, 222, 0.08);
        --color-accent-gradient: linear-gradient(135deg, #009ADE 0%, #0080c0 100%);

        --color-text: #334155;
        --color-text-muted: #64748b;
        --color-text-heading: #0f172a;

        --color-white: #ffffff;
        --color-success: #22c55e;
        --color-warning: #eab308;

        /* Typography */
        --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
        --font-size-xs: 0.8rem;
        --font-size-sm: 0.9rem;
        --font-size-base: 1rem;
        --font-size-lg: 1.125rem;
        --font-size-xl: 1.25rem;
        --font-size-2xl: 1.5rem;
        --font-size-3xl: 2rem;
        --font-size-4xl: 2.75rem;
        --font-size-5xl: 3.5rem;

        /* Spacing */
        --space-xs: 0.5rem;
        --space-sm: 0.75rem;
        --space-md: 1rem;
        --space-lg: 1.5rem;
        --space-xl: 2rem;
        --space-2xl: 3rem;
        --space-3xl: 4rem;
        --space-4xl: 6rem;

        /* Layout */
        --max-width: 1200px;
        --radius-sm: 6px;
        --radius-md: 10px;
        --radius-lg: 16px;

        /* Transitions */
        --transition-fast: 150ms ease;
        --transition-base: 250ms ease;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-family: var(--font-sans);
        color: var(--color-text);
        background: var(--color-dark);
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        line-height: 1.7;
        font-size: var(--font-size-base);
      }

      main {
        flex: 1;
      }

      a {
        color: var(--color-accent);
        text-decoration: none;
        transition: color var(--transition-fast);
      }

      a:hover {
        color: var(--color-accent-light);
      }

      img {
        max-width: 100%;
        height: auto;
      }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 var(--space-lg);
      }

      /* Buttons */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: var(--space-xs);
        padding: 0.8rem 1.75rem;
        border-radius: var(--radius-sm);
        font-weight: 600;
        font-size: var(--font-size-base);
        transition: all var(--transition-base);
        border: none;
        cursor: pointer;
        text-decoration: none;
      }

      .btn-primary {
        background: var(--color-accent-gradient);
        color: var(--color-white);
        box-shadow: 0 0 20px var(--color-accent-glow);
      }

      .btn-primary:hover {
        color: var(--color-white);
        transform: translateY(-2px);
        box-shadow: 0 0 30px rgba(0, 154, 222, 0.3);
      }

      .btn-secondary {
        border: 1px solid var(--color-dark-border);
        color: var(--color-text);
        background: transparent;
      }

      .btn-secondary:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
        background: var(--color-accent-glow);
      }

      /* Card base */
      .card {
        background: var(--color-dark-card);
        border: 1px solid var(--color-dark-border);
        border-radius: var(--radius-md);
        padding: var(--space-xl);
        transition: all var(--transition-base);
      }

      .card:hover {
        border-color: var(--color-accent);
        box-shadow: 0 4px 20px rgba(0, 154, 222, 0.12);
      }

      /* Section spacing */
      .section {
        padding: var(--space-4xl) 0;
      }

      .section-header {
        margin-bottom: var(--space-2xl);
      }

      .section-header h2 {
        font-size: var(--font-size-3xl);
        font-weight: 700;
        color: var(--color-text-heading);
        line-height: 1.2;
      }

      .section-header p {
        color: var(--color-text-muted);
        font-size: var(--font-size-lg);
        margin-top: var(--space-sm);
        max-width: 600px;
      }

      /* Badge */
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 100px;
        font-size: var(--font-size-xs);
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        border: 1px solid var(--color-dark-border);
        color: var(--color-accent);
        background: var(--color-accent-glow);
      }

      /* Responsive */
      @media (max-width: 768px) {
        .section {
          padding: var(--space-3xl) 0;
        }

        .section-header h2 {
          font-size: var(--font-size-2xl);
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
